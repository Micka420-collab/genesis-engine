# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.tox/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual envs ---
venv/
.venv/
env/
ENV/

# --- IDE / Editors ---
.vscode/
.idea/
.claude/
*.swp
*~
.DS_Store
Thumbs.db
~$*.docx
~$*.xlsx

# --- Genesis Engine runtime artefacts ---
# Earth-data cache (Copernicus DEM, ESA WorldCover) — regenerated on demand
cache/
# But the Rust `cache` crate is source code, not a regenerated cache —
# the broad `cache/` rule above accidentally hid it from git and broke CI
# when the workspace tried to load its manifest. Keep this exception
# pinned (negation of the directory above).
!native/world-engine/crates/cache/
!native/world-engine/crates/cache/**
# Simulation journals — huge JSONL streams, regenerated by runs
runtime/journals/
# Earth Console live session logs (regenerated by run_earth_console.py)
artifacts/
# Local JSONL streams produced by Rust/dev scenarios
runtime/data/*.jsonl
# Exports (GeoTIFF/PNG/OBJ/JSON snapshots) — output artefacts
runtime/exports/
# Persisted world library — local checkpoints, not source code
worlds/
# Profile output
runtime/journals/profile_tick.txt
# Deprecated prototype tree — keep only the ImportError redirect stub.
# See runtime/genesis/__init__.py for the supported entry-point message.
runtime/genesis/*
!runtime/genesis/__init__.py

# --- Rust build artefacts (scaffolding crates) ---
scaffolding/target/
**/target/debug/
**/target/release/
**/*.rlib
**/*.rmeta
Cargo.lock.bak

# --- Logs ---
*.log
*.log.*
logs/
