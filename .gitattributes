# Normalize line endings across platforms.
# Without this, every Windows commit prints LF→CRLF warnings and risks
# polluting diffs with EOL-only changes.

* text=auto eol=lf

# --- Source code: always LF ---
*.py     text eol=lf
*.rs     text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.html   text eol=lf
*.js     text eol=lf
*.css    text eol=lf
*.sh     text eol=lf
Makefile text eol=lf

# --- Windows-native scripts: always CRLF ---
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# --- Binary assets: never touch ---
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.docx   binary
*.xlsx   binary
*.zip    binary
*.gz     binary
*.tar    binary
*.tif    binary
*.tiff   binary
*.parquet binary
*.npz    binary
*.npy    binary
